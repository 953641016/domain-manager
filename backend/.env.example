# ==============================================================================
# 域名管家 - 环境变量配置示例
# 复制此文件为 .env 并填入真实配置值
# ==============================================================================

# ------------------------------------------------------------------------------
# 域名和 CORS 配置
# ------------------------------------------------------------------------------
# 前端 Web 访问域名
FRONTEND_DOMAIN=domainmgr.yourcompany.com
# 后端 API 域名
BACKEND_DOMAIN=api.domainmgr.yourcompany.com
# 允许的 CORS origins（逗号分隔）
ALLOWED_ORIGINS=http://localhost:3000,https://domainmgr.yourcompany.com
# 前端基础URL（用于OAuth回调）
FRONTEND_BASE_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# JWT 认证配置
# ------------------------------------------------------------------------------
# JWT 密钥（生产环境必须使用强随机密钥）
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=your_jwt_secret_key_here
# JWT 算法
JWT_ALGORITHM=HS256
# Access Token 有效期（分钟）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ------------------------------------------------------------------------------
# 数据加密配置
# ------------------------------------------------------------------------------
# Fernet 加密密钥（用于加密 API Key 等敏感数据）
# 生成方式: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here

# ------------------------------------------------------------------------------
# 钉钉机器人配置
# ------------------------------------------------------------------------------
DINGTALK_APP_KEY=your_app_key_here
DINGTALK_APP_SECRET=your_app_secret_here

# ------------------------------------------------------------------------------
# 飞书应用配置
# ------------------------------------------------------------------------------
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 超级管理员飞书用户ID
SUPER_ADMIN_FEISHU_USER_ID=ou_super_admin_user_id
# 可选：读取飞书文档/多维表格使用的应用；为空时复用 FEISHU_APP_ID/SECRET
FEISHU_DOC_APP_ID=
FEISHU_DOC_APP_SECRET=
# 后端接口域名默认解析目标，例如 115.28.211.155
BACKEND_DNS_DEFAULT_TARGET=

# ------------------------------------------------------------------------------
# Cloudflare 配置
# ------------------------------------------------------------------------------
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=optional_account_id

# ------------------------------------------------------------------------------
# GoDaddy 配置
# ------------------------------------------------------------------------------
GODADDY_API_KEY=your_godaddy_api_key
GODADDY_API_SECRET=your_godaddy_api_secret

# ------------------------------------------------------------------------------
# DNSPod (腾讯云) 配置
# ------------------------------------------------------------------------------
DNSPOD_SECRET_ID=your_tencentcloud_secret_id
DNSPOD_SECRET_KEY=your_tencentcloud_secret_key

# ------------------------------------------------------------------------------
# 数据库配置
# ------------------------------------------------------------------------------
DATABASE_URL=sqlite:///./data/domain_manager.db

# ------------------------------------------------------------------------------
# 域名专员（管理员）飞书用户ID，多个用逗号分隔
# ------------------------------------------------------------------------------
ADMIN_USER_IDS=user1,user2,user3

# ------------------------------------------------------------------------------
# 日志配置
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
