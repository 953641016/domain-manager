# ==============================================================================
# Docker Compose 环境变量配置示例
# 复制此文件为 .env 并填入真实配置值
# ==============================================================================

# ------------------------------------------------------------------------------
# 域名和 CORS 配置
# ------------------------------------------------------------------------------
FRONTEND_DOMAIN=localhost
BACKEND_DOMAIN=localhost
ALLOWED_ORIGINS=http://localhost,http://localhost:3000
FRONTEND_BASE_URL=http://localhost

# ------------------------------------------------------------------------------
# JWT 认证配置
# ------------------------------------------------------------------------------
JWT_SECRET_KEY=change-this-to-a-strong-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ------------------------------------------------------------------------------
# 数据加密配置
# ------------------------------------------------------------------------------
ENCRYPTION_KEY=change-this-to-your-fernet-key

# ------------------------------------------------------------------------------
# 飞书应用配置
# ------------------------------------------------------------------------------
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPER_ADMIN_FEISHU_USER_ID=ou_xxxxxxxxxxxxxxxx

# ------------------------------------------------------------------------------
# Cloudflare 配置
# ------------------------------------------------------------------------------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ------------------------------------------------------------------------------
# GoDaddy 配置
# ------------------------------------------------------------------------------
GODADDY_API_KEY=
GODADDY_API_SECRET=

# ------------------------------------------------------------------------------
# DNSPod (腾讯云) 配置
# ------------------------------------------------------------------------------
DNSPOD_SECRET_ID=
DNSPOD_SECRET_KEY=

# ------------------------------------------------------------------------------
# 数据库配置
# ------------------------------------------------------------------------------
DATABASE_URL=sqlite:///./data/domain_manager.db

# ------------------------------------------------------------------------------
# 管理员配置
# ------------------------------------------------------------------------------
ADMIN_USER_IDS=

# ------------------------------------------------------------------------------
# 日志配置
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
